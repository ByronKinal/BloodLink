                  "  if (response.refreshToken) pm.environment.set('refreshTokenDonor', response.refreshToken);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshTokenDonor}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/refresh-token",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "refresh-token"
              ]
            },
            "description": "Rota refresh token del Donor y genera nuevo access token."
          },
          "response": []
        },
