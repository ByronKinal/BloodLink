    "name": "BloodLink - Auth y Roles",
    "description": "Colección para probar autenticación, Access/Refresh Token, verificación por correo y administración de roles en BloodLink (PostgreSQL).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "description": "Endpoints de registro, verificación de cuenta, login, refresh token, recuperación y restablecimiento.",
      "item": [
        {
          "name": "1. Register Donor",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const response = pm.response.json();",
                  "  if (response.user && response.user.id) {",
                  "    pm.environment.set('userId', response.user.id);",
                  "    pm.environment.set('targetUserId', response.user.id);",
                  "  }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Juan\",\n  \"surname\": \"Pérez\",\n  \"username\": \"{{testUsername}}\",\n  \"email\": \"{{testEmail}}\",\n  \"password\": \"{{testPassword}}\",\n  \"phone\": \"{{testPhone}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "register"
              ]
            },
            "description": "Registra un usuario nuevo y guarda userId/targetUserId automáticamente."
          },
          "response": []
        },
        {
          "name": "2. Verify Email (Token)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"{{verificationToken}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/verify-email",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "verify-email"
              ]
            },
            "description": "Verifica la cuenta usando token (copiado del correo o logs)."
          },
          "response": []
        },
        {
          "name": "3. Verify Email (Activation Code)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{testEmail}}\",\n  \"activationCode\": \"{{activationCode}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/verify-email",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "verify-email"
              ]
            },
            "description": "Verifica la cuenta usando email + código de activación."
          },
          "response": []
        },
        {
          "name": "4. Login Donor",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const response = pm.response.json();",
                  "  if (response.accessToken) pm.environment.set('tokenDonor', response.accessToken);",
                  "  if (response.refreshToken) pm.environment.set('refreshTokenDonor', response.refreshToken);",
                  "  if (response.userDetails && response.userDetails.id) {",
                  "    pm.environment.set('userId', response.userDetails.id);",
                  "    if (!pm.environment.get('targetUserId')) pm.environment.set('targetUserId', response.userDetails.id);",
                  "  }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"emailOrUsername\": \"{{testEmail}}\",\n  \"password\": \"{{testPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            },
            "description": "Inicia sesión de Donor y guarda tokenDonor/refreshTokenDonor."
          },
          "response": []
        },
