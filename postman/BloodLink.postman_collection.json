            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"roleName\": \"{{roleName}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/users/{{targetUserId}}/role",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "users",
                "{{targetUserId}}",
                "role"
              ]
            },
            "description": "Cambia rol de cualquier usuario. Solo ADMIN_ROLE."
          },
          "response": []
        },
