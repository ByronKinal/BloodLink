    {
      "name": "Roles",
      "description": "Todos estos endpoints requieren tokenAdmin en Authorization Bearer.",
      "item": [
        {
          "name": "1. Get Allowed Roles (Admin)",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{tokenAdmin}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/users/allowed-roles",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "users",
                "allowed-roles"
              ]
            },
            "description": "Lista roles permitidos. Solo ADMIN_ROLE."
          },
          "response": []
        },
        {
          "name": "2. Get User Roles (Admin)",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{tokenAdmin}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/users/{{targetUserId}}/roles",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "users",
                "{{targetUserId}}",
                "roles"
              ]
            },
            "description": "Consulta roles de cualquier usuario. Solo ADMIN_ROLE."
          },
          "response": []
        },
        {
          "name": "3. Change User Role (Admin)",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{tokenAdmin}}",
                  "type": "string"
